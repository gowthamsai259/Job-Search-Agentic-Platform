# Copy to .env and adjust. All values are optional (defaults shown).

# Paths (useful when mounting data/artifacts as Docker volumes)
# DATA_DIR=/app/data
# ARTIFACTS_DIR=/app/data/artifacts
# CLEANED_CSV=/app/data/postings_cleaned.csv

# Model tunables
TFIDF_MAX_FEATURES=5000
RECOMMEND_TOP_N=5

# Build the model from CSV on startup if artifacts are missing (slow; off by default)
BUILD_ON_STARTUP=false

# Comma-separated allowed CORS origins (use exact origins in production, not *)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
