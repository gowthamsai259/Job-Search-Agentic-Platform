# Copy to .env and fill in real values. All values are optional except Supabase
# (needed to build artifacts).

# Supabase: source of truth for job data (table must have `title`, `description`)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-publishable-or-anon-key
SUPABASE_TABLE=postings_cleaned
SUPABASE_PAGE_SIZE=1000

# Paths (useful when mounting data/artifacts as Docker volumes)
# DATA_DIR=/app/data
# ARTIFACTS_DIR=/app/data/artifacts

# Model tunables
TFIDF_MAX_FEATURES=5000
RECOMMEND_TOP_N=5

# Build the model on startup if artifacts are missing (slow; off by default)
BUILD_ON_STARTUP=false

# Comma-separated allowed CORS origins (use exact origins in production, not *)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000
